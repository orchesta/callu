# ╔══════════════════════════════════════════════════════════════╗
# ║  Callu — environment for the full Docker stack                 ║
# ║  (db, redis, rabbitmq, api, worker, web)                       ║
# ╠══════════════════════════════════════════════════════════════╣
# ║  Copy this file to .env and fill in the values marked CHANGE_ME ║
# ║  before running `docker compose up -d`. NEVER commit your .env. ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── PostgreSQL (callu-db service) ───────────────────────────
POSTGRES_DB=calludb
POSTGRES_USER=callu
# Required. Use a long random password.
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ─── API / Worker → database (internal network: service name) ─
DB_HOST=callu-db
DB_PORT=5432

# ─── RabbitMQ (callu-rabbitmq) — required by MassTransit ──────
RABBITMQ_USER=callu
# Required. Use a long random password.
RABBITMQ_PASS=CHANGE_ME_strong_rabbitmq_password
# RABBITMQ_HOST=callu-rabbitmq
RABBITMQ_MGMT_PORT=15672

# ─── Redis (callu-redis) — HybridCache L2 + SignalR backplane ─
REDIS_CONNECTION=callu-redis:6379

# ─── JWT ─────────────────────────────────────────────────────
# Required. Must be at least 32 characters — the API refuses to start otherwise.
# Generate a strong key, e.g.:  openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_generate_a_strong_random_key_min_32_chars
JWT_ISSUER=CalluApp
JWT_AUDIENCE=CalluApp
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=7

# ─── Web (nginx) ─────────────────────────────────────────────
WEB_PORT=3000
# Set these to your public URL in production (e.g. https://callu.example.com).
CORS_ORIGINS=http://localhost:3000
CALLU_PUBLIC_URL=http://localhost:3000

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=Warning

# ─── Quartz (Worker) ─────────────────────────────────────────
QUARTZ_USE_PERSISTENT_STORE=false

# ─── OpenTelemetry / Jaeger (default: on, internal Docker network) ─
# OTLP :4317 is not published to the host — only the api/worker containers
# reach callu-jaeger:4317. The Jaeger UI is bound to this machine only:
# http://127.0.0.1:16686 (not reachable from the LAN).
# Set OPEN_TELEMETRY_ENABLED=false to turn telemetry off entirely.
OPEN_TELEMETRY_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://callu-jaeger:4317
JAEGER_UI_PORT=16686
