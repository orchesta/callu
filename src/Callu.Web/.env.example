# CalluApp Web - Environment Variables
# Copy this file to .env and fill in the values
# ALL variables are REQUIRED — app will throw if any is missing

# Backend API base URL (no trailing slash, no /api suffix)\nVITE_API_URL=http://localhost:5095

# Auth token localStorage key
VITE_AUTH_TOKEN_KEY=calluapp_auth_token

# API request timeout in milliseconds
VITE_API_TIMEOUT=30000
