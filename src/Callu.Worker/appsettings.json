{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "Quartz": {
    "UsePersistentStore": false
  },
  "RabbitMQ": {
    "Host": "",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  },
  "CommunicationSettings": {
    "DisableSslValidation": true,
    "SystemSipTrunkId": null
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Quartz": "Warning",
        "MassTransit": "Warning",
        "StackExchange.Redis": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}      {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "",
    "CaptureDbStatements": false
  }
}
